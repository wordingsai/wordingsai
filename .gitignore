# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

google-cloud-sdk
.vscode
.cursor
backup_file.sql

.vercel

# Internal project assets (Notion exports, sample PDFs, chat logs)
resources/

# One-off dev scripts that don't need to ship
scripts/upload-test-contract.mjs
.env.vercel-import
scripts/_pp.mjs
# Throwaway scratch scripts (underscore-prefixed). Real scripts keep their name.
scripts/_*.mjs
scripts/_*.cjs
scripts/_*.ts
scripts/_*.py

# Large binaries must never be committed (sample contracts, exports, snapshots)
*.pdf
*.zip
*.bak
*.sql

# Prod env pulled via `vercel env pull` (secrets — never commit)
_prod.env
*.prod.env

# Python bytecode
__pycache__/
*.pyc
